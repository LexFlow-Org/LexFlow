{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "LexFlow default capabilities — Maximum security, zero network access",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "opener:default",
    "opener:allow-open-path",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-request-permission",
    "notification:allow-is-permission-granted",
    "notification:allow-show",
    "notification:allow-cancel",
    "notification:allow-get-pending",
    "notification:allow-get-active",
    "notification:allow-remove-active",
    "notification:allow-batch",
    "notification:allow-check-permissions",
    "notification:allow-permission-state",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/typst",
          "sidecar": true,
          "args": [
            "compile",
            { "validator": "\\S+" },
            { "validator": "\\S+" },
            "--font-path",
            { "validator": "\\S+" }
          ]
        },
        {
          "name": "binaries/typst",
          "sidecar": true,
          "args": [
            "compile",
            { "validator": "\\S+" },
            { "validator": "\\S+" }
          ]
        },
        {
          "name": "binaries/qpdf",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
