<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- LSUIElement: false — LexFlow is a full desktop app (not a menubar-only agent).
         Showing in the Dock ensures reliable notification permission dialogs,
         proper System Settings > Notifications registration, and correct TCC tracking.
         The system tray icon still works alongside the Dock icon (like Slack/Discord). -->
    <key>LSUIElement</key>
    <false/>

    <!-- Calendar access — EventKit permission prompt -->
    <key>NSCalendarsUsageDescription</key>
    <string>LexFlow sincronizza udienze e scadenze con il Calendario di sistema per mantenerti sempre aggiornato.</string>

    <!-- Full calendar access (macOS 14+ Sonoma) -->
    <key>NSCalendarsFullAccessUsageDescription</key>
    <string>LexFlow necessita dell'accesso completo al Calendario per creare e aggiornare automaticamente gli eventi legali.</string>

    <!-- Alert-style notifications (not banners) — persist on screen -->
    <key>NSUserNotificationAlertStyle</key>
    <string>alert</string>
</dict>
</plist>
