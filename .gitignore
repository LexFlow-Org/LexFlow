client/dist/

# Build artifacts
*.dmg
*.exe
*.blockmap
*.ipa
*.apk
*.aab

# OS files
.DS_Store
Thumbs.db
.metadata_never_index

# Environment & Secrets -- NEVER commit
.env
.env.*
*.keystore
*.jks
*.p12
*.pfx
*.pem
*.key
keystore_base64.txt

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# Temp
*.tmp
*.bak

# License key registry (encrypted local files -- NEVER commit)
scripts/.lexflow-issued-keys.enc
scripts/.lexflow-registry-salt
scripts/lexflow-keys-export.csv

# Generated platform icons
src-tauri/icons/android/
src-tauri/icons/ios/

# Typst sidecar binaries (too large for git, downloaded at build time)
src-tauri/binaries/

# Python
__pycache__/
*.pyc
